{
        "compilerOptions": {
                "target": "ES2022",
                "module": "commonjs",
                "outDir": "./dist",
                "rootDir": "./src",

                // PENGATURAN TOLERAN untuk migrasi bertahap
                "allowJs": true, // izinkan .js & .ts bersamaan
                "checkJs": false, // jangan check .js file dulu
                // "strict": false,              // mulai dari loose, ketatkan bertahap
                "strict": true,
                // "noImplicitAny": false,       // izinkan 'any' dulu
                "noImplicitAny": true,
                "esModuleInterop": true,
                "skipLibCheck": true,
                "resolveJsonModule": true
        },
        "include": ["src/**/*", "src/drizzle.config.ts"],
        "exclude": ["node_modules", "dist"]
}
